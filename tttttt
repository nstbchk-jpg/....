import requests
import urllib3
import json

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

SEPM_IP = "*********"
USER    = "***********"
PASS    = "**********"

BASE_URL = f"https://{SEPM_IP}:8446/sepm/api/v1"

auth_res = requests.post(
    f"{BASE_URL}/identity/authenticate",
    json={"username": USER, "password": PASS, "domain": ""},
    verify=False
)
token = auth_res.json()["token"]
headers = {"Authorization": f"Bearer {token}"}

res = requests.get(
    f"{BASE_URL}/policies/summary",
    params={"pageSize": 100},
    headers=headers,
    verify=False
)
policies = res.json().get("content", [])

# Знаходимо першу робочу політику
for policy in policies:
    policy_id = policy.get("id")
    policy_name = policy.get("name")
    
    detail_res = requests.get(
        f"{BASE_URL}/policies/exceptions/{policy_id}",
        headers=headers,
        verify=False
    )
    
    if detail_res.status_code == 200:
        policy_data = detail_res.json()
        print(f"Політика: {policy_name}\n")
        print("configuration ключі:")
        config = policy_data.get("configuration", {})
        print(list(config.keys()))
        print(f"\nwhitelistrules в configuration:")
        print(json.dumps(config.get("whitelistrules", [])[:1], indent=2))
        print(f"\nПеший whitelistrule повністю:")
        if config.get("whitelistrules"):
            print(json.dumps(config.get("whitelistrules")[0], indent=2))
        break
