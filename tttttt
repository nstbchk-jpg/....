import requests
import urllib3
import json

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

SEPM_IP = "*********"
USER    = "***********"
PASS    = "**********"

BASE_URL = f"https://{SEPM_IP}:8446/sepm/api/v1"

auth_res = requests.post(
    f"{BASE_URL}/identity/authenticate",
    json={"username": USER, "password": PASS, "domain": ""},
    verify=False
)
token = auth_res.json()["token"]
headers = {"Authorization": f"Bearer {token}"}

res = requests.get(
    f"{BASE_URL}/policies/summary",
    params={"pageSize": 100},
    headers=headers,
    verify=False
)
policies = res.json().get("content", [])

for policy in policies:
    policy_id = policy.get("id")
    policy_name = policy.get("name")
    
    detail_res = requests.get(
        f"{BASE_URL}/policies/exceptions/{policy_id}",
        headers=headers,
        verify=False
    )
    
    if detail_res.status_code == 200:
        policy_data = detail_res.json()
        raw = json.dumps(policy_data)
        
        # Шукаємо політику де є whitelistrules або blacklistrules на верхньому рівні
        if "whitelistrules" in raw or ("blacklistrules" in raw and len(policy_data.get("blacklistrules", [])) > 0):
            print(f"Знайшло: {policy_name}")
            print(f"Топ-рівневі ключі: {list(policy_data.keys())}")
            print(f"\nwhitelistrules: {len(policy_data.get('whitelistrules', []))}")
            print(f"blacklistrules: {len(policy_data.get('blacklistrules', []))}")
            
            if policy_data.get('whitelistrules'):
                print(f"\nПеший whitelistrule:")
                print(json.dumps(policy_data.get('whitelistrules')[0], indent=2))
            
            if policy_data.get('blacklistrules'):
                print(f"\nПеший blacklistrule:")
                print(json.dumps(policy_data.get('blacklistrules')[0], indent=2))
            
            break
