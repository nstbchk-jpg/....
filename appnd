#!/usr/bin/env python3
"""Діагностика GET /policy-objects/fingerprints — показує статус і тіло відповіді."""
import requests, urllib3, json
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

SEPM_IP = "*********"
USER    = "***********"
PASS    = "**********"
BASE_URL = f"https://{SEPM_IP}:8446/sepm/api/v1"

s = requests.Session()
tok = s.post(f"{BASE_URL}/identity/authenticate",
             json={"username": USER, "password": PASS, "domain": ""},
             verify=False, timeout=30).json()["token"]
s.headers.update({"Authorization": f"Bearer {tok}"})
print("auth ok\n")

def try_get(label, url, **params):
    r = s.get(url, params=params or None, verify=False, timeout=30)
    print(f"--- {label}")
    print(f"    URL:    {r.url}")
    print(f"    status: {r.status_code}")
    print(f"    body:   {r.text[:400]}\n")
    return r

FP = f"{BASE_URL}/policy-objects/fingerprints"

try_get("bare",                 FP)
try_get("pageIndex/pageSize",   FP, pageIndex=1, pageSize=100)
try_get("sort/pageSize",        FP, pageSize=100, sort="NAME")
