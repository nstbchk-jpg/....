#!/usr/bin/env python3
"""
READ-ONLY. Знаходить політику 'SOC Test App' у /policies/summary,
показує її id + тип, і пробує дотягнути її деталі різними ендпоінтами.
Нічого не змінює.
"""
import requests, urllib3, json
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# ── КОНФІГ ─────────────────────────────────────────────
SEPM_IP  = "*********"
USER     = "***********"
PASS     = "**********"
DOMAIN   = ""
BASE_URL = f"https://{SEPM_IP}:8446/sepm/api/v1"
TARGET   = "SOC Test App"
VERIFY_TLS = False
# ───────────────────────────────────────────────────────

s = requests.Session()
tok = s.post(f"{BASE_URL}/identity/authenticate",
             json={"username": USER, "password": PASS, "domain": DOMAIN},
             verify=VERIFY_TLS, timeout=30).json()["token"]
s.headers.update({"Authorization": f"Bearer {tok}"})
print("auth ok\n")

# 1. SUMMARY усіх політик
r = s.get(f"{BASE_URL}/policies/summary",
          params={"pageIndex": 1, "pageSize": 200},
          verify=VERIFY_TLS, timeout=30)
print(f"GET /policies/summary -> HTTP {r.status_code}")
if r.status_code != 200:
    print(r.text[:500]); raise SystemExit
data = r.json()
content = data.get("content", data if isinstance(data, list) else [])
print(f"всього політик у відповіді: {len(content)}\n")

if content:
    print("=== ключі одного елемента summary ===")
    print(list(content[0].keys()), "\n")

# 2. знайти нашу політику за іменем
matches = [p for p in content if (p.get("name") or "").strip() == TARGET]
if not matches:
    # часткові збіги на випадок пробілів/регістру
    matches = [p for p in content if TARGET.lower() in (p.get("name") or "").lower()]

if not matches:
    print(f"'{TARGET}' у summary не знайдено. Ось усі імена+типи:")
    for p in content:
        print(f"  - {p.get('name')!r:45}  type={p.get('policytype') or p.get('contenttype') or p.get('type')}")
    raise SystemExit

print("=== ЗНАЙДЕНО ===")
for p in matches:
    print(json.dumps(p, indent=2, ensure_ascii=False))

pol = matches[0]
pid = pol.get("id")
ptype = pol.get("policytype") or pol.get("contenttype") or pol.get("type")
print(f"\nid={pid}  type={ptype}\n")

# 3. пробуємо дотягнути ДЕТАЛІ політики різними шляхами
candidates = [
    f"/policies/{ptype}/{pid}" if ptype else None,
    f"/policies/adc/{pid}",
    f"/policies/application-and-device-control/{pid}",
    f"/policies/app-device-control/{pid}",
    f"/policies/{pid}",
]
print("=== ПРОБА ДЕТАЛЕЙ ===")
for path in filter(None, candidates):
    rr = s.get(f"{BASE_URL}{path}", verify=VERIFY_TLS, timeout=30)
    print(f"\n--- GET {path} -> HTTP {rr.status_code}")
    print(f"    body: {rr.text[:300]}")
