import requests
import urllib3
import json

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

SEPM_IP = "*********"
USER    = "***********"
PASS    = "**********"
CHECK_HASH = "твой_хеш"

BASE_URL = f"https://{SEPM_IP}:8446/sepm/api/v1"

auth_res = requests.post(
    f"{BASE_URL}/identity/authenticate",
    json={"username": USER, "password": PASS, "domain": ""},
    verify=False
)
token = auth_res.json()["token"]
headers = {"Authorization": f"Bearer {token}"}

res = requests.get(
    f"{BASE_URL}/policies/summary",
    params={"pageSize": 100},
    headers=headers,
    verify=False
)
policies = res.json().get("content", [])

# Берем первую политику с whitelistrules
for policy in policies:
    policy_id = policy.get("id")
    policy_name = policy.get("name")
    
    get_res = requests.get(
        f"{BASE_URL}/policies/exceptions/{policy_id}",
        headers=headers,
        verify=False
    )
    
    if get_res.status_code == 200:
        policy_data = get_res.json()
        config = policy_data.get("configuration", {})
        
        if config.get("whitelistrules"):
            # Берем первое правило как шаблон
            template = config["whitelistrules"][0]
            print(f"Политика: {policy_name}\n")
            print("Шаблон первого правила:")
            print(json.dumps(template, indent=2))
            
            # Пытаемся добавить копию
            new_rule = json.loads(json.dumps(template))  # Глубокая копия
            new_rule["processfile"]["sha2"] = CHECK_HASH
            
            config["whitelistrules"].append(new_rule)
            policy_data["configuration"] = config
            
            put_res = requests.put(
                f"{BASE_URL}/policies/exceptions/{policy_id}",
                json=policy_data,
                headers=headers,
                verify=False
            )
            
            print(f"\nОтправка PUT: {put_res.status_code}")
            if put_res.status_code != 200:
                print(f"Ошибка: {put_res.text[:300]}")
            
            break
