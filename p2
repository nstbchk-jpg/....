import urllib.parse

# Тест 1 — параметри в URL а не в body
res = requests.post(
    f"{BASE_URL}/command-queue/activescan",
    params={"computer_ids": comp_id},
    headers=headers,
    verify=False
)
print(f"Тест 1: {res.status_code} | {res.text[:200]}")

# Тест 2 — form data замість json
res = requests.post(
    f"{BASE_URL}/command-queue/activescan",
    data={"computer_ids": comp_id},
    headers=headers,
    verify=False
)
print(f"Тест 2: {res.status_code} | {res.text[:200]}")

# Тест 3 — вручну серіалізований JSON рядок
res = requests.post(
    f"{BASE_URL}/command-queue/activescan",
    data=json.dumps({"computer_ids": [comp_id]}),
    headers={**headers, "Content-Type": "application/json"},
    verify=False
)
print(f"Тест 3: {res.status_code} | {res.text[:200]}")

# Тест 4 — activescan з computer_ids в URL
res = requests.post(
    f"{BASE_URL}/command-queue/activescan?computer_ids={comp_id}",
    headers=headers,
    verify=False
)
print(f"Тест 4: {res.status_code} | {res.text[:200]}")

# Тест 5 — fullscan з group_ids в URL
res = requests.post(
